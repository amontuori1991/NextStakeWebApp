@page
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
}

@model NextStakeWebApp.Pages.Events.IndexModel
@functions {
    string FormatScore(int? goals, string? statusShort)
    {
        var st = (statusShort ?? "").Trim().ToUpperInvariant();
        if (st == "NS" || st == "PST")
            return "-";
        if (!goals.HasValue)
            return "0";
        return goals.Value.ToString();
    }
}

@using System.Globalization
@using System.Runtime.InteropServices
@{
    var it = new CultureInfo("it-IT");
    var today = DateOnly.FromDateTime(DateTime.Now);
    var sel = Model.SelectedDate;
    var dayName = it.TextInfo.ToTitleCase(sel.ToDateTime(TimeOnly.MinValue).ToString("dddd", it));
    var firstOfMonth = new DateOnly(sel.Year, sel.Month, 1);
    var lastOfMonth = firstOfMonth.AddMonths(1).AddDays(-1);
    var startCal = firstOfMonth;
    while (startCal.DayOfWeek != DayOfWeek.Monday) startCal = startCal.AddDays(-1);
    var endCal = lastOfMonth;
    while (endCal.DayOfWeek != DayOfWeek.Sunday) endCal = endCal.AddDays(1);
    var common =
        $"&fav={(Model.OnlyFavorites ? 1 : 0)}&country={Model.SelectedCountryCode}&q={Model.Query}"
        + (Model.ShowBest ? "&best=1" : "")
        + (Model.ShowExchange ? "&ex=1" : "")
        + (Request.Query["ex2"] == "1" ? "&ex2=1" : "");
}

@{
    ViewData["Title"] = "Eventi";
}

<div class="events-page">
    <div class="container py-4">
        <div class="row g-3">

            <!-- ═══════════════════════════════════════════
                 SIDEBAR
                 ═══════════════════════════════════════════ -->
            <aside class="col-12 col-lg-3">
                <!-- Calendario -->
                <div class="card mb-3">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <a class="btn btn-sm btn-outline-secondary"
                           href="/Events?d=@firstOfMonth.AddMonths(-1).ToString("yyyy-MM-dd")@common"
                           aria-label="Mese precedente">←</a>
                        <div class="fw-semibold small text-center">
                            @it.TextInfo.ToTitleCase(firstOfMonth.ToDateTime(TimeOnly.MinValue).ToString("MMMM", it)) @firstOfMonth.Year
                        </div>
                        <a class="btn btn-sm btn-outline-secondary"
                           href="/Events?d=@firstOfMonth.AddMonths(1).ToString("yyyy-MM-dd")@common"
                           aria-label="Mese successivo">→</a>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <small class="text-muted">Lun</small>
                            <small class="text-muted">Mar</small>
                            <small class="text-muted">Mer</small>
                            <small class="text-muted">Gio</small>
                            <small class="text-muted">Ven</small>
                            <small class="text-muted">Sab</small>
                            <small class="text-muted">Dom</small>
                        </div>
                        <div class="mini-cal">
                            @{
                                var d = startCal;
                                while (d <= endCal)
                                {
                                    <div class="mini-cal-row">
                                        @for (int i = 0; i < 7; i++)
                                        {
                                            var isOutside = d < firstOfMonth || d > lastOfMonth;
                                            var isToday = d == today;
                                            var isSelected = d == sel;
                                            <a class="mini-cal-day @(isOutside ? "cal-outside" : "") @(isToday ? "is-today" : "") @(isSelected ? "is-selected" : "")"
                                               href="/Events?d=@d.ToString("yyyy-MM-dd")@common">
                                                @d.Day
                                            </a>
                                            ;
                                            d = d.AddDays(1);
                                        }
                                    </div>
                                }
                            }
                        </div>
                        <div class="d-grid mt-2">
                            <a class="btn btn-sm btn-outline-primary"
                               href="/Events?d=@today.ToString("yyyy-MM-dd")@common">Oggi</a>
                        </div>
                    </div>
                </div>

                <!-- Bottoni filtro + AI -->
                <div class="d-grid gap-2 mb-3">
                    <a class="btn @(Model.OnlyFavorites ? "btn-warning" : "btn-outline-warning")"
                       href="/Events?d=@Model.SelectedDate.ToString("yyyy-MM-dd")&fav=@(Model.OnlyFavorites ? 0 : 1)&country=@Model.SelectedCountryCode&q=@Model.Query">
                        ⭐ @(Model.OnlyFavorites ? "Mostra tutti" : "Vedi preferiti")
                    </a>

                    @{
                        var isSelectedToday = Model.SelectedDate == DateOnly.FromDateTime(DateTime.Now);
                        var bestDisabled = !isSelectedToday || !Model.HasBestCandidatesToday;
                        var exchangeDisabled = !isSelectedToday || !Model.HasExchangeCandidatesToday;
                        var exchangeOtherDisabled = !isSelectedToday || !Model.HasExchangeOtherCandidatesToday;
                    }

                    <a class="btn btn-success @(bestDisabled ? "disabled" : "")"
                       href="@(bestDisabled ? "#" : $"/Events?d={Model.SelectedDate:yyyy-MM-dd}&fav={(Model.OnlyFavorites ? 1 : 0)}&country={Model.SelectedCountryCode}&q={Model.Query}&best=1")"
                       data-loading="best"
                       aria-disabled="@(bestDisabled ? "true" : "false")"
                       tabindex="@(bestDisabled ? "-1" : "0")"
                       title="@(bestDisabled ? (isSelectedToday ? "Nessun candidato disponibile oggi." : "Disponibile solo su Oggi.") : "")">
                        Migliori pronostici di oggi
                    </a>
                    @if (bestDisabled)
                    {
                        <small class="text-muted d-block">
                            @(isSelectedToday ? "Nessun candidato disponibile oggi." : "Disponibile solo su Oggi.")
                        </small>
                    }

                    <a class="btn btn-primary @(exchangeDisabled ? "disabled" : "")"
                       href="@(exchangeDisabled ? "#" : $"/Events?d={Model.SelectedDate:yyyy-MM-dd}&fav={(Model.OnlyFavorites ? 1 : 0)}&country={Model.SelectedCountryCode}&q={Model.Query}&ex=1")"
                       data-loading="exchange"
                       aria-disabled="@(exchangeDisabled ? "true" : "false")"
                       tabindex="@(exchangeDisabled ? "-1" : "0")"
                       title="@(exchangeDisabled ? (isSelectedToday ? "Nessun candidato Exchange disponibile oggi." : "Disponibile solo su Oggi.") : "")">
                        Migliori Exchange di oggi
                    </a>
                    @if (exchangeDisabled)
                    {
                        <small class="text-muted d-block">
                            @(isSelectedToday ? "Nessun candidato Exchange disponibile oggi." : "Disponibile solo su Oggi.")
                        </small>
                    }

                    <a class="btn btn-info @(exchangeOtherDisabled ? "disabled" : "")"
                       href="@(exchangeOtherDisabled ? "#" : $"/Events?d={Model.SelectedDate:yyyy-MM-dd}&fav={(Model.OnlyFavorites ? 1 : 0)}&country={Model.SelectedCountryCode}&q={Model.Query}&ex2=1")"
                       data-loading="exchangeOther"
                       aria-disabled="@(exchangeOtherDisabled ? "true" : "false")"
                       tabindex="@(exchangeOtherDisabled ? "-1" : "0")"
                       title="@(exchangeOtherDisabled ? (isSelectedToday ? "Nessun candidato Exchange (Altri Risultati) disponibile oggi." : "Disponibile solo su Oggi.") : "")">
                        Migliori Exchange - Altri risultati
                    </a>
                    @if (exchangeOtherDisabled)
                    {
                        <small class="text-muted d-block">
                            @(isSelectedToday ? "Nessun candidato Exchange (Altri Risultati) disponibile oggi." : "Disponibile solo su Oggi.")
                        </small>
                    }

                    @if (Model.ShowExchange)
                    {
                        <a class="btn btn-outline-secondary"
                           href="/Events?d=@Model.SelectedDate.ToString("yyyy-MM-dd")&fav=@(Model.OnlyFavorites ? 1 : 0)&country=@Model.SelectedCountryCode&q=@Model.Query">
                            Nascondi exchange
                        </a>
                    }
                    @if (Model.ShowBest)
                    {
                        <a class="btn btn-outline-secondary"
                           href="/Events?d=@Model.SelectedDate.ToString("yyyy-MM-dd")&fav=@(Model.OnlyFavorites ? 1 : 0)&country=@Model.SelectedCountryCode&q=@Model.Query">
                            Nascondi pronostici
                        </a>
                    }

                    <!-- ═══════════════════════════════════════
                         SEZIONE AI
                         ═══════════════════════════════════════ -->
                    <hr class="my-1" />
                    <div class="fw-semibold small text-muted mb-1">🤖 Analisi AI</div>

                    <button type="button"
                            id="btn-scalata-ai"
                            class="btn btn-scalata-ai"
                            @(!isSelectedToday ? "disabled" : "")
                            title="@(!isSelectedToday ? "Disponibile solo su Oggi." : "Costruisce una scalata ottimale con l'AI")">
                        🎯 Scalata AI
                    </button>

                    <button type="button"
                            id="btn-singola-ai"
                            class="btn btn-singola-ai"
                            @(!isSelectedToday ? "disabled" : "")
                            title="@(!isSelectedToday ? "Disponibile solo su Oggi." : "Trova la migliore singola di valore")">
                        💎 Singola di Valore
                    </button>

                    <button type="button"
                            id="btn-multipla-ai"
                            class="btn btn-multipla-ai"
                            @(!isSelectedToday ? "disabled" : "")
                            title="@(!isSelectedToday ? "Disponibile solo su Oggi." : "Costruisce una multipla con quota target")">
                        🎲 Multipla AI
                    </button>

                    <!-- Input quota multipla (nascosto di default) -->
                    <div id="multipla-input-panel" class="d-none mt-1">
                        <div class="input-group input-group-sm">
                            <input type="number"
                                   id="multipla-quota-input"
                                   class="form-control"
                                   placeholder="Quota target (es. 5.00)"
                                   min="1.5"
                                   step="0.5"
                                   value="5.00" />
                            <button type="button"
                                    id="btn-multipla-confirm"
                                    class="btn btn-primary btn-sm">OK</button>
                        </div>
                        <small class="text-muted">Min. 1.50 — premi OK o Invio</small>
                    </div>

                    @if (!isSelectedToday)
                    {
                        <small class="text-muted d-block">L'analisi AI è disponibile solo su Oggi.</small>
                    }
                </div>

                <!-- Tema -->
                <div class="card p-3 mb-3">
                    <div class="d-flex align-items-center justify-content-between">
                        <label class="form-label fw-semibold mb-0">Tema interfaccia</label>
                        <small class="text-muted">salvato per i prossimi accessi</small>
                    </div>
                    <div class="d-flex gap-2 mt-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-theme-choice="light">Light</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-theme-choice="dark">Dark</button>
                    </div>
                </div>

                <!-- Notifiche -->
                <div class="card p-3 mb-3">
                    <div class="d-flex align-items-center justify-content-between">
                        <span class="form-label fw-semibold mb-0">Notifiche match preferiti</span>
                        <div class="d-flex gap-2">
                            <button type="button" id="btn-push-test" class="btn btn-sm btn-outline-secondary">Test notifica</button>
                            <button type="button" id="btn-push-toggle" class="btn btn-sm btn-outline-primary">Attiva notifiche</button>
                        </div>
                    </div>
                    <small class="text-muted d-block mt-2">
                        Ricevi una notifica su inizio/fine e gol dei match che hai messo tra i preferiti.
                    </small>
                    <div id="push-status" class="small text-muted mt-1"></div>
                </div>

                <!-- Filtri -->
                <form method="get" action="/Events" class="card p-3 mb-3">
                    <div class="mb-2">
                        <label class="form-label">Filtro Nazione</label>
                        <select class="form-select form-select-sm" name="country" onchange="this.form.submit()">
                            <option value="">— Mostra tutte —</option>
                            @foreach (var c in Model.AvailableCountries)
                            {
                                <option value="@c.Code" selected="@(Model.SelectedCountryCode == c.Code)">
                                    @c.Name (@c.Code)
                                </option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Cerca (squadra o competizione)</label>
                        <input class="form-control form-control-sm" type="text" name="q" value="@Model.Query"
                               placeholder="Es: Serie A, Inter, Premier..." />
                    </div>
                    <input type="hidden" name="d" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="fav" value="@(Model.OnlyFavorites ? 1 : 0)" />
                    @if (Model.ShowBest)
                    {
                        <input type="hidden" name="best" value="1" />
                    }
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-sm">Filtra</button>
                    </div>
                </form>
            </aside>

            <!-- ═══════════════════════════════════════════
                 MAIN
                 ═══════════════════════════════════════════ -->
            <main class="col-12 col-lg-9">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="h5 mb-0">
                        @dayName @Model.SelectedDate.ToString("dd/MM/yyyy")
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        <button id="btn-live-filter" type="button" class="btn btn-sm btn-outline-danger fw-bold">
                            🔴 LIVE
                        </button>
                        <a class="btn btn-outline-secondary"
                           href="/Events?d=@Model.SelectedDate.AddDays(-1).ToString("yyyy-MM-dd")@common">←</a>
                        <a class="btn btn-outline-secondary"
                           href="/Events?d=@Model.SelectedDate.AddDays(1).ToString("yyyy-MM-dd")@common">→</a>
                    </div>
                </div>

                <!-- ── Best picks ── -->
                @if (Model.ShowBest)
                {
                    <div class="card mb-4 exchange-picks">
                        <div class="card-header d-flex align-items-center justify-content-between">
                            <div class="fw-semibold">🔥 Migliori pronostici</div>
                            <small class="text-muted">Ordinati per data/ora</small>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrWhiteSpace(Model.BestMessage))
                            {
                                <div class="alert alert-info mb-3">@Model.BestMessage</div>
                            }
                            @{
                                var bestItems = (Model.BestPicks ?? new List<NextStakeWebApp.Models.BestPickRow>())
                                    .OrderBy(x => x.EventDate)
                                    .Select(r =>
                                    {
                                        Model.AssetsByMatchId.TryGetValue(r.Id, out var a);
                                        var comp = r.Competition ?? "";
                                        var split = comp.Split(" - ", 2, StringSplitOptions.TrimEntries);
                                        var countryCode = split.Length > 0 ? split[0] : "";
                                        var leagueName = split.Length > 1 ? split[1] : comp;
                                        return new { R = r, A = a, Country = countryCode, League = leagueName, Flag = a?.LeagueFlag, Logo = a?.LeagueLogo };
                                    })
                                    .ToList();
                                var gi = 0;
                            }
                            @if (bestItems.Count == 0)
                            {
                                <div class="alert alert-secondary mb-0">Nessun pronostico disponibile al momento.</div>
                            }
                            else
                            {
                                @foreach (var grp in bestItems.GroupBy(x => new { x.Country, x.League, x.Flag, x.Logo }))
                                {
                                    var gid = $"bestgrp-{++gi}";
                                    <div class="mb-3 border rounded">
                                        <button class="w-100 text-start league-toggle-btn border-0"
                                                type="button" data-bs-toggle="collapse" data-bs-target="#@gid"
                                                aria-expanded="true" aria-controls="@gid">
                                            <div class="d-flex align-items-center justify-content-between py-2 px-3">
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="toggle-caret">▾</span>
                                                    @if (!string.IsNullOrWhiteSpace(grp.Key.Logo))
                                                    {
                                                        <img src="@grp.Key.Logo" alt="league-logo" style="height:18px;width:auto;" />
                                                    }
                                                    <span class="fw-semibold">@grp.Key.League</span>
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(grp.Key.Country) || !string.IsNullOrWhiteSpace(grp.Key.Flag))
                                                {
                                                    <div class="d-flex align-items-center gap-1 text-muted">
                                                        @if (!string.IsNullOrWhiteSpace(grp.Key.Country))
                                                        {
                                                            <span>@grp.Key.Country</span>
                                                        }
                                                        @if (!string.IsNullOrWhiteSpace(grp.Key.Flag))
                                                        {
                                                            <img src="@grp.Key.Flag" alt="flag" style="height:14px;width:auto;vertical-align:middle;" />
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </button>
                                        <div id="@gid" class="collapse show">
                                            <div class="list-group list-group-flush">
                                                @foreach (var bp in grp)
                                                {
                                                    var parts = (bp.R.Match ?? "").Split(" - ", 2, StringSplitOptions.TrimEntries);
                                                    var homeName = parts.Length > 0 ? parts[0] : bp.R.Match;
                                                    var awayName = parts.Length > 1 ? parts[1] : "";
                                                    var ko = bp.R.EventDate.ToString("dd/MM HH:mm");
                                                    <div class="list-group-item">
                                                        <div class="match-item">
                                                            <a href="/Match/Details?id=@bp.R.Id&d=@Model.SelectedDate.ToString("yyyy-MM-dd")@common" class="match-grid">
                                                                <div class="team home">
                                                                    <span class="team-logo-box">
                                                                        @if (!string.IsNullOrWhiteSpace(bp.A?.HomeLogo))
                                                                        {
                                                                            <img src="@bp.A.HomeLogo" alt="home" class="team-logo" />
                                                                        }
                                                                    </span>
                                                                    <span class="team-name">@homeName</span>
                                                                </div>
                                                                <div class="center">
                                                                    <span class="vs-pill">vs</span>
                                                                    <small class="text-muted mt-1">@ko</small>
                                                                </div>
                                                                <div class="team away">
                                                                    <span class="team-name">@awayName</span>
                                                                    <span class="team-logo-box">
                                                                        @if (!string.IsNullOrWhiteSpace(bp.A?.AwayLogo))
                                                                        {
                                                                            <img src="@bp.A.AwayLogo" alt="away" class="team-logo" />
                                                                        }
                                                                    </span>
                                                                </div>
                                                                <div class="home-score">–</div>
                                                                <div class="score-sep">:</div>
                                                                <div class="away-score">–</div>
                                                            </a>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }

                <!-- ── Exchange ── -->
                @if (Model.ShowExchange)
                {
                    <div class="card mb-4 exchange-picks" id="exchangePicks">
                        <div class="card-header d-flex align-items-center justify-content-between">
                            <div class="fw-semibold">⚡ Migliori Exchange di oggi</div>
                            <small class="text-muted">Ordinati per rating</small>
                        </div>
                        <div class="card-body">
                            @{
                                var exItems = (Model.ExchangePicks ?? new List<NextStakeWebApp.Models.ExchangeTodayRow>())
                                    .OrderByDescending(x => x.Rating).ThenBy(x => x.Match_Date)
                                    .Select(r => { Model.AssetsByMatchId.TryGetValue(r.Match_Id, out var a); return new { R = r, A = a }; })
                                    .ToList();
                            }
                            @if (exItems.Count == 0)
                            {
                                if (!string.IsNullOrWhiteSpace(Model.ExchangeMessage))
                                {
                                    <div class="alert alert-info mb-0">@Model.ExchangeMessage</div>
                                }
                                else
                                {
                                    <div class="alert alert-secondary mb-0">Nessun candidato exchange disponibile al momento.</div>
                                }
                            }
                            else
                            {
                                if (!string.IsNullOrWhiteSpace(Model.ExchangeMessage))
                                {
                                    <div class="alert alert-info mb-3">@Model.ExchangeMessage</div>
                                }
                                <div class="list-group list-group-flush">
                                    @foreach (var row in exItems)
                                    {
                                        var ko = row.R.Match_Date.ToString("dd/MM HH:mm");
                                        var rating = Convert.ToDouble(row.R.Rating);
                                        var stakePct = (rating <= 85) ? 1 : (rating < 90 ? 2 : 3);
                                        <div class="list-group-item exchange-row" data-rating="@row.R.Rating">
                                            @if (!string.IsNullOrWhiteSpace(row.R.Score_To_Lay_Contrarian))
                                            {
                                                <div class="ex-lay-float">
                                                    <span class="badge badge-lay">LAY: @row.R.Score_To_Lay_Contrarian</span>
                                                </div>
                                            }
                                            <a href="/Match/Details?id=@row.R.Match_Id&d=@Model.SelectedDate.ToString("yyyy-MM-dd")@common"
                                               class="match-grid ex-match-grid">
                                                <div class="team home">
                                                    <span class="team-logo-box">
                                                        @if (!string.IsNullOrWhiteSpace(row.A?.HomeLogo))
                                                        {
                                                            <img src="@row.A.HomeLogo" alt="home" class="team-logo" />
                                                        }
                                                    </span>
                                                    <span class="team-name">@row.R.Home_Name</span>
                                                </div>
                                                <div class="center ex-vs"><span class="vs-pill">vs</span></div>
                                                <div class="ex-meta">
                                                    <div class="ex-ko">@ko</div>
                                                    <div class="ex-info">
                                                        Rating: <b>@row.R.Rating</b> |
                                                        Stake suggerito: <b>@stakePct%</b> |
                                                        xG: <b>@((row.R.Xg_Pred_Total ?? 0).ToString("0.00"))</b>
                                                    </div>
                                                    <div class="ex-score">
                                                        <span class="home-score">–</span>
                                                        <span class="score-sep">:</span>
                                                        <span class="away-score">–</span>
                                                    </div>
                                                </div>
                                                <div class="team away">
                                                    <span class="team-name">@row.R.Away_Name</span>
                                                    <span class="team-logo-box">
                                                        @if (!string.IsNullOrWhiteSpace(row.A?.AwayLogo))
                                                        {
                                                            <img src="@row.A.AwayLogo" alt="away" class="team-logo" />
                                                        }
                                                    </span>
                                                </div>
                                            </a>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- ── Exchange Other ── -->
                @if (Model.ShowExchangeOther)
                {
                    <div class="card mb-4 exchange-picks" id="exchangeOtherPicks">
                        <div class="card-header d-flex align-items-center justify-content-between">
                            <div class="fw-semibold">🧩 Migliori Exchange - Altri risultati</div>
                            <small class="text-muted">Ordinati per rating</small>
                        </div>
                        <div class="card-body">
                            @{
                                var ex2Items = (Model.ExchangeOtherPicks ?? new List<NextStakeWebApp.Models.ExchangeOtherTodayRow>())
                                    .OrderByDescending(x => x.Rating).ThenBy(x => x.Match_Date)
                                    .Select(r => { Model.AssetsByMatchId.TryGetValue(r.Match_Id, out var a); return new { R = r, A = a }; })
                                    .ToList();
                            }
                            @if (ex2Items.Count == 0)
                            {
                                if (!string.IsNullOrWhiteSpace(Model.ExchangeOtherMessage))
                                {
                                    <div class="alert alert-info mb-0">@Model.ExchangeOtherMessage</div>
                                }
                                else
                                {
                                    <div class="alert alert-secondary mb-0">Nessun candidato exchange (altri risultati) disponibile al momento.</div>
                                }
                            }
                            else
                            {
                                if (!string.IsNullOrWhiteSpace(Model.ExchangeOtherMessage))
                                {
                                    <div class="alert alert-info mb-3">@Model.ExchangeOtherMessage</div>
                                }
                                <div class="list-group list-group-flush">
                                    @foreach (var row in ex2Items)
                                    {
                                        var ko = row.R.Match_Date.ToString("dd/MM HH:mm");
                                        var rating = Convert.ToDouble(row.R.Rating);
                                        var stakePct = (rating <= 85) ? 1 : (rating < 90 ? 2 : 3);
                                        <div class="list-group-item exchange-row" data-rating="@row.R.Rating">
                                            @if (!string.IsNullOrWhiteSpace(row.R.Score_To_Lay))
                                            {
                                                <div class="ex-lay-float">
                                                    <span class="badge badge-lay">LAY: @row.R.Score_To_Lay</span>
                                                </div>
                                            }
                                            <a href="/Match/Details?id=@row.R.Match_Id&d=@Model.SelectedDate.ToString("yyyy-MM-dd")@common"
                                               class="match-grid ex-match-grid">
                                                <div class="team home">
                                                    <span class="team-logo-box">
                                                        @if (!string.IsNullOrWhiteSpace(row.A?.HomeLogo))
                                                        {
                                                            <img src="@row.A.HomeLogo" alt="home" class="team-logo" />
                                                        }
                                                    </span>
                                                    <span class="team-name">@row.R.Home_Name</span>
                                                </div>
                                                <div class="center ex-vs"><span class="vs-pill">vs</span></div>
                                                <div class="ex-meta">
                                                    <div class="ex-ko">@ko</div>
                                                    <div class="ex-info">
                                                        Rating: <b>@row.R.Rating</b> |
                                                        Stake suggerito: <b>@stakePct%</b> |
                                                        xG: <b>@((row.R.Xg_Pred_Total ?? 0).ToString("0.00"))</b>
                                                    </div>
                                                    <div class="ex-score">
                                                        <span class="home-score">–</span>
                                                        <span class="score-sep">:</span>
                                                        <span class="away-score">–</span>
                                                    </div>
                                                </div>
                                                <div class="team away">
                                                    <span class="team-name">@row.R.Away_Name</span>
                                                    <span class="team-logo-box">
                                                        @if (!string.IsNullOrWhiteSpace(row.A?.AwayLogo))
                                                        {
                                                            <img src="@row.A.AwayLogo" alt="away" class="team-logo" />
                                                        }
                                                    </span>
                                                </div>
                                            </a>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- ═══════════════════════════════════════
                     SEZIONI AI (populate via JavaScript)
                     ═══════════════════════════════════════ -->

                <!-- Scalata AI -->
                <div id="section-scalata-ai" class="d-none card mb-4 ai-picks">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <div class="fw-semibold">🎯 Scalata AI</div>
                        <small class="text-muted">3-6 pick ad alta confidenza</small>
                    </div>
                    <div class="card-body">
                        <div id="scalata-loading" class="text-center py-3 d-none">
                            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                            <span>L'AI sta costruendo la scalata ottimale...</span>
                        </div>
                        <div id="scalata-error" class="alert alert-warning d-none"></div>
                        <div id="scalata-summary" class="alert alert-info d-none mb-3"></div>
                        <div class="d-flex align-items-center justify-content-between mb-3 d-none" id="scalata-quota-row">
                            <span class="fw-semibold">Quota totale:</span>
                            <span id="scalata-quota-totale" class="badge bg-primary fs-6"></span>
                        </div>
                        <div id="scalata-picks-list"></div>
                    </div>
                </div>

                <!-- Singola di Valore -->
                <div id="section-singola-ai" class="d-none card mb-4 ai-picks singola-picks">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <div class="fw-semibold">💎 Singola di Valore</div>
                        <small class="text-muted">La migliore singola del giorno</small>
                    </div>
                    <div class="card-body">
                        <div id="singola-loading" class="text-center py-3 d-none">
                            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                            <span>L'AI sta cercando la migliore singola di valore...</span>
                        </div>
                        <div id="singola-error" class="alert alert-warning d-none"></div>
                        <div id="singola-summary" class="alert alert-info d-none mb-3"></div>
                        <div class="d-flex align-items-center justify-content-between mb-3 d-none" id="singola-quota-row">
                            <span class="fw-semibold">Quota:</span>
                            <span id="singola-quota-totale" class="badge bg-warning text-dark fs-6"></span>
                        </div>
                        <div id="singola-picks-list"></div>
                    </div>
                </div>

                <!-- Multipla AI -->
                <div id="section-multipla-ai" class="d-none card mb-4 ai-picks multipla-picks">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <div class="fw-semibold">🎲 Multipla AI</div>
                        <small class="text-muted" id="multipla-subtitle"></small>
                    </div>
                    <div class="card-body">
                        <div id="multipla-loading" class="text-center py-3 d-none">
                            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                            <span id="multipla-loading-text">L'AI sta costruendo la multipla...</span>
                        </div>
                        <div id="multipla-error" class="alert alert-warning d-none"></div>
                        <div id="multipla-summary" class="alert alert-info d-none mb-3"></div>
                        <div class="d-flex align-items-center justify-content-between mb-3 d-none" id="multipla-quota-row">
                            <span class="fw-semibold">Quota totale:</span>
                            <span id="multipla-quota-totale" class="badge bg-info text-dark fs-6"></span>
                        </div>
                        <div id="multipla-picks-list"></div>
                    </div>
                </div>

                <!-- ── Lista eventi ── -->
                @if (!Model.ShowExchange && !Model.ShowExchangeOther && !Model.ShowBest && Model.Rows.Count == 0)
                {
                    <p>Nessuna partita trovata per il giorno selezionato.</p>
                }
                else
                {
                    @foreach (var group in Model.Rows.GroupBy(r => new { r.LeagueId, r.LeagueName, r.LeagueLogo, r.CountryName, r.LeagueFlag }))
                    {
                        var groupId = $"lg-{group.Key.LeagueId}";
                        <div class="mb-3 border rounded">
                            <button class="w-100 text-start league-toggle-btn border-0"
                                    type="button" data-bs-toggle="collapse" data-bs-target="#@groupId"
                                    aria-expanded="true" aria-controls="@groupId">
                                <div class="d-flex align-items-center justify-content-between py-2 px-3">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="toggle-caret">▾</span>
                                        @if (!string.IsNullOrWhiteSpace(group.Key.LeagueLogo))
                                        {
                                            <img src="@group.Key.LeagueLogo" alt="league-logo" style="height:18px;width:auto;" />
                                        }
                                        <span class="fw-semibold">@group.Key.LeagueName</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(group.Key.CountryName) || !string.IsNullOrWhiteSpace(group.Key.LeagueFlag))
                                    {
                                        <div class="d-flex align-items-center gap-1 text-muted">
                                            @if (!string.IsNullOrWhiteSpace(group.Key.CountryName))
                                            {
                                                <span>@group.Key.CountryName</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(group.Key.LeagueFlag))
                                            {
                                                <img src="@group.Key.LeagueFlag" alt="flag" style="height:14px;width:auto;vertical-align:middle;" />
                                            }
                                        </div>
                                    }
                                </div>
                            </button>
                            <div id="@groupId" class="collapse show">
                                <div class="list-group list-group-flush">
                                    @foreach (var r in group)
                                    {
                                        var isLive = r.StatusShort == "1H" || r.StatusShort == "2H" || r.StatusShort == "ET"
                                            || r.StatusShort == "P" || r.StatusShort == "BT" || r.StatusShort == "HT" || r.StatusShort == "LIVE";
                                        var isFav = Model.FavoriteMatchIds.Contains(r.MatchId);
                                        <div class="list-group-item"
                                             data-live="@(isLive ? "1" : "0")"
                                             data-fixture-root="@r.MatchId"
                                             data-fav="@(isFav ? "1" : "0")"
                                             data-league-name="@group.Key.LeagueName"
                                             data-league-logo="@group.Key.LeagueLogo">
                                            <div class="match-item">
                                                @{
                                                    var homeScoreStr = FormatScore(r.HomeGoal, r.StatusShort);
                                                    var awayScoreStr = FormatScore(r.AwayGoal, r.StatusShort);
                                                    var ko = r.KickoffLocal.ToString("HH:mm");
                                                }
                                                <a href="/Match/Details?id=@r.MatchId&d=@Model.SelectedDate.ToString("yyyy-MM-dd")@common" class="match-grid">
                                                    <div class="team home">
                                                        <span class="team-logo-box">
                                                            @if (!string.IsNullOrWhiteSpace(r.HomeLogo))
                                                            {
                                                                <img src="@r.HomeLogo" alt="home" class="team-logo" />
                                                            }
                                                        </span>
                                                        <span class="team-name">@r.Home</span>
                                                    </div>
                                                    <div class="center">
                                                        <span class="vs-pill">vs</span>
                                                        <small class="text-muted mt-1">Ora: @ko</small>
                                                        <small class="live-minute d-none" data-fixture="@r.MatchId"></small>
                                                    </div>
                                                    <div class="team away">
                                                        <span class="team-name">@r.Away</span>
                                                        <span class="team-logo-box">
                                                            @if (!string.IsNullOrWhiteSpace(r.AwayLogo))
                                                            {
                                                                <img src="@r.AwayLogo" alt="away" class="team-logo" />
                                                            }
                                                        </span>
                                                    </div>
                                                    <div class="home-score" data-fixture="@r.MatchId" data-side="home">@homeScoreStr</div>
                                                    <div class="score-sep">:</div>
                                                    <div class="away-score" data-fixture="@r.MatchId" data-side="away">@awayScoreStr</div>
                                                </a>
                                                <form method="post"
                                                      action="/Events?handler=ToggleFavorite&matchId=@r.MatchId&d=@Model.SelectedDate.ToString("yyyy-MM-dd")&fav=@(Model.OnlyFavorites?1:0)&country=@Model.SelectedCountryCode&q=@Model.Query@(Model.ShowBest ? "&best=1" : "")"
                                                      class="fav-form">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit"
                                                            class="btn btn-sm @(isFav ? "btn-warning" : "btn-outline-secondary")"
                                                            title="Aggiungi/rimuovi dai preferiti">
                                                        ⭐
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            </main>
        </div>
    </div>
</div>

<!-- Loading overlay -->
<div id="loadingOverlay" class="loading-overlay d-none" aria-hidden="true">
    <div class="loading-panel">
        <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
        <span id="loadingMessage">Caricamento…</span>
    </div>
</div>

@section Scripts {
    <script>
        // Loading overlay per link normali
        (function () {
            const overlay = document.getElementById('loadingOverlay');
            const msgEl = document.getElementById('loadingMessage');
            function showOverlay(message) {
                if (msgEl && message) msgEl.textContent = message;
                if (overlay) overlay.classList.remove('d-none');
            }
            document.addEventListener('click', function (e) {
                const bestBtn = e.target.closest('a[data-loading="best"]');
                if (bestBtn) { showOverlay('Caricamento migliori pronostici…'); return; }
                const matchLink = e.target.closest('a.match-grid');
                if (matchLink) { showOverlay('Caricamento match in corso…'); return; }
                const exBtn = e.target.closest('a[data-loading="exchange"]');
                if (exBtn) { showOverlay('Caricamento migliori exchange…'); return; }
                const exOtherBtn = e.target.closest('a[data-loading="exchangeOther"]');
                if (exOtherBtn) { showOverlay('Caricamento exchange (altri risultati)…'); return; }
                const generic = e.target.closest('a[data-loading-message]');
                if (generic) { showOverlay(generic.getAttribute('data-loading-message') || 'Caricamento…'); }
            });
            window.addEventListener('pageshow', () => { if (overlay) overlay.classList.add('d-none'); });
        })();
    </script>

    <script>
        // Tema
        (function () {
            function currentChoice() {
                const cookieMatch = document.cookie.match(/(?:^|;\s*)theme=([^;]+)/);
                const cookieValue = cookieMatch ? decodeURIComponent(cookieMatch[1]) : null;
                const stored = cookieValue || localStorage.getItem('theme');
                if (stored === 'light' || stored === 'dark') return stored;
                return 'dark';
            }
            function applyTheme(choice) {
                document.documentElement.setAttribute('data-theme', (choice === 'light') ? 'light' : 'dark');
            }
            function persist(choice) {
                const applied = (choice === 'light') ? 'light' : 'dark';
                localStorage.setItem('theme', applied);
                document.cookie = "theme=" + encodeURIComponent(applied) + "; path=/; max-age=31536000; samesite=lax";
            }
            async function saveServer(choice) {
                try {
                    await fetch('?handler=SetTheme', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'fetch' },
                        body: JSON.stringify({ theme: (choice === 'light') ? 'light' : 'dark' })
                    });
                } catch { }
            }
            const btns = document.querySelectorAll('[data-theme-choice]');
            btns.forEach(b => {
                b.addEventListener('click', async () => {
                    const choice = b.getAttribute('data-theme-choice');
                    applyTheme(choice); persist(choice); await saveServer(choice);
                    btns.forEach(x => x.classList.remove('active'));
                    b.classList.add('active');
                });
            });
            const choice = currentChoice();
            applyTheme(choice);
            const active = document.querySelector(`[data-theme-choice="${choice}"]`);
            if (active) active.classList.add('active');
        })();
    </script>

    <script>
        // Scroll automatico exchange
        (function () {
            const qs = new URLSearchParams(location.search);
            if (qs.get('ex') === '1') {
                setTimeout(() => document.getElementById('exchangePicks')?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 150);
            }
            if (qs.get('ex2') === '1') {
                setTimeout(() => document.getElementById('exchangeOtherPicks')?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 150);
            }
        })();
    </script>

    <script>
        // ═══════════════════════════════════════════════════
        // ANALISI AI — Scalata, Singola, Multipla
        // ═══════════════════════════════════════════════════
        (function () {

            // ── Helpers ──────────────────────────────────
            function flag(code) {
                const map = {
                    'IT':'🇮🇹','GB-ENG':'🏴󠁧󠁢󠁥󠁮󠁧󠁿','ES':'🇪🇸','DE':'🇩🇪','FR':'🇫🇷',
                    'PT':'🇵🇹','NL':'🇳🇱','BE':'🇧🇪','TR':'🇹🇷','AR':'🇦🇷',
                    'BR':'🇧🇷','US':'🇺🇸','LT':'🇱🇹','EG':'🇪🇬','MX':'🇲🇽'
                };
                return map[code] || '🌍';
            }

            // Il server restituisce DateTime come UTC ma i dati sono già ora Italia
            // quindi leggiamo le ore UTC direttamente (non convertiamo)
            function formatTime(isoStr) {
                if (!isoStr) return '--:--';
                const d = new Date(isoStr);
                return String(d.getUTCHours()).padStart(2,'0') + ':' + String(d.getUTCMinutes()).padStart(2,'0');
            }

            function logoHtml(url, alt) {
                if (!url) return '';
                return `<img src="${url}" alt="${alt}" style="height:20px;width:auto;object-fit:contain;vertical-align:middle;" />`;
            }

            function buildPickHtml(pick, badgeClass) {
                const confClass = pick.confidenza === 'ALTA' ? 'badge-confidenza-alta' : 'badge-confidenza-media';
                return `
                <div class="ai-pick-card">
                    <div class="ai-pick-header">
                        <div class="ai-pick-match">
                            ${logoHtml(pick.homeLogo, pick.homeName)}
                            ${pick.homeName}
                            <span class="text-muted mx-1">vs</span>
                            ${pick.awayName}
                            ${logoHtml(pick.awayLogo, pick.awayName)}
                        </div>
                        <span class="badge badge-pick ${badgeClass}">${pick.pick} @@ ${pick.quotaStimata.toFixed(2)}</span>
                    </div>
                    <div class="ai-pick-meta">
                        ${flag(pick.countryCode)} ${pick.leagueName || ''}
                        &nbsp;·&nbsp; ⏰ ${formatTime(pick.kickoff)}
                        &nbsp;·&nbsp; <span class="badge ${confClass}">${pick.confidenza}</span>
                    </div>
                    ${pick.motivazione ? `<div class="ai-motivazione">💬 ${pick.motivazione}</div>` : ''}
                </div>`;
            }

            function showSection(id) {
                const el = document.getElementById(id);
                if (!el) return;
                el.classList.remove('d-none');
                setTimeout(() => el.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
            }

            function setLoading(prefix, visible) {
                const el = document.getElementById(prefix + '-loading');
                if (el) el.classList.toggle('d-none', !visible);
            }

            function showError(prefix, msg) {
                const el = document.getElementById(prefix + '-error');
                if (el) { el.textContent = msg; el.classList.remove('d-none'); }
            }

            function clearSection(prefix) {
                const ids = ['loading','error','summary','quota-row','picks-list'];
                ids.forEach(s => {
                    const el = document.getElementById(prefix + '-' + s);
                    if (!el) return;
                    if (s === 'picks-list') el.innerHTML = '';
                    else if (s === 'quota-row') el.classList.add('d-none');
                    else { el.classList.add('d-none'); if (s !== 'loading') el.textContent = ''; }
                });
            }

            function renderPicks(prefix, data, badgeClass) {
                if (data.summary) {
                    const el = document.getElementById(prefix + '-summary');
                    if (el) { el.textContent = data.summary; el.classList.remove('d-none'); }
                }
                if (data.quotaTotale && data.quotaTotale > 1) {
                    const qRow = document.getElementById(prefix + '-quota-row');
                    const qVal = document.getElementById(prefix + '-quota-totale');
                    if (qRow && qVal) { qVal.textContent = data.quotaTotale.toFixed(2); qRow.classList.remove('d-none'); }
                }
                const list = document.getElementById(prefix + '-picks-list');
                if (!list) return;
                if (!data.picks || data.picks.length === 0) {
                    list.innerHTML = '<div class="alert alert-secondary">Nessun pick disponibile al momento.</div>';
                    return;
                }
                list.innerHTML = data.picks.map(p => buildPickHtml(p, badgeClass)).join('');
            }

            async function callApi(url) {
                const res = await fetch(url, { credentials: 'include' });
                if (!res.ok) throw new Error('Errore server: HTTP ' + res.status);
                return await res.json();
            }

            // ── Scalata AI ────────────────────────────────
            document.getElementById('btn-scalata-ai')?.addEventListener('click', async () => {
                clearSection('scalata');
                showSection('section-scalata-ai');
                setLoading('scalata', true);
                try {
                    const data = await callApi('/api/events/scalata');
                    renderPicks('scalata', data, 'badge-pick-scalata');
                } catch (e) {
                    showError('scalata', 'Errore: ' + e.message);
                } finally {
                    setLoading('scalata', false);
                }
            });

            // ── Singola di Valore ─────────────────────────
            document.getElementById('btn-singola-ai')?.addEventListener('click', async () => {
                clearSection('singola');
                showSection('section-singola-ai');
                setLoading('singola', true);
                try {
                    const data = await callApi('/api/events/singola');
                    renderPicks('singola', data, 'badge-pick-singola');
                } catch (e) {
                    showError('singola', 'Errore: ' + e.message);
                } finally {
                    setLoading('singola', false);
                }
            });

            // ── Multipla AI ───────────────────────────────
            const btnMultipla = document.getElementById('btn-multipla-ai');
            const multiplaPanel = document.getElementById('multipla-input-panel');
            const btnConfirm = document.getElementById('btn-multipla-confirm');
            const quotaInput = document.getElementById('multipla-quota-input');

            btnMultipla?.addEventListener('click', () => {
                multiplaPanel?.classList.toggle('d-none');
                quotaInput?.focus();
            });

            async function loadMultipla() {
                const raw = (quotaInput?.value ?? '5.00').replace(',', '.');
                const quota = parseFloat(raw);
                if (isNaN(quota) || quota < 1.5) {
                    alert('Inserisci una quota target valida (min. 1.50)');
                    return;
                }
                multiplaPanel?.classList.add('d-none');
                const subtitle = document.getElementById('multipla-subtitle');
                if (subtitle) subtitle.textContent = `Quota target: ${quota.toFixed(2)}`;
                const loadingText = document.getElementById('multipla-loading-text');
                if (loadingText) loadingText.textContent = `L'AI sta costruendo una multipla da ${quota.toFixed(2)}...`;

                clearSection('multipla');
                showSection('section-multipla-ai');
                setLoading('multipla', true);
                try {
                    const data = await callApi(`/api/events/multipla?quotaTarget=${quota.toFixed(2)}`);
                    renderPicks('multipla', data, 'badge-pick-multipla');
                } catch (e) {
                    showError('multipla', 'Errore: ' + e.message);
                } finally {
                    setLoading('multipla', false);
                }
            }

            btnConfirm?.addEventListener('click', loadMultipla);
            quotaInput?.addEventListener('keydown', e => { if (e.key === 'Enter') loadMultipla(); });

        })();
    </script>
}

@section Styles {
    <text>
        <style>
            /* ═══════════════════════════════════════════
               THEME VARS
               ═══════════════════════════════════════════ */
            :root[data-theme="dark"] {
                --bg: linear-gradient(135deg, #252e40 0%, #1a2230 100%);
                --text: #e9edf3;
                --muted-text: rgba(255,255,255,.6);
                --card: rgba(255,255,255,0.06);
                --border: rgba(255,255,255,0.16);
                --divider: rgba(255,255,255,0.14);
                --select-bg: #1f2a3a;
                --select-bg-focus: #213044;
                --select-text: #e9edf3;
                --link: #7bd3ff;
                --link-hover: #9be0ff;
                --primary: #00baff;
                --primary-hover: #009cdc;
                --mini-day: rgba(255,255,255,.08);
                --mini-day-hover: rgba(255,255,255,.14);
                --mini-day-border: rgba(255,255,255,.20);
                --league-toggle-bg: #2b3445;
                --league-toggle-bg-hover: #364056;
                --vs-border: rgba(255,255,255,.22);
                --list-border: rgba(255,255,255,.20);
                --live: #dc3545;
                --live-soft: #ff6b6b;
            }
            :root[data-theme="light"] {
                --bg: #f0f2f5;
                --text: #1a2230;
                --muted-text: #566079;
                --card: #ffffff;
                --border: rgba(0,0,0,0.10);
                --divider: rgba(0,0,0,0.12);
                --select-bg: #ffffff;
                --select-bg-focus: #ffffff;
                --select-text: #1a2230;
                --link: #0d6efd;
                --link-hover: #0b5ed7;
                --primary: #0d6efd;
                --primary-hover: #0b5ed7;
                --mini-day: #ffffff;
                --mini-day-hover: #f2f4f8;
                --mini-day-border: rgba(0,0,0,.12);
                --league-toggle-bg: #f7f7f7;
                --league-toggle-bg-hover: #e9ecef;
                --vs-border: rgba(0,0,0,.12);
                --list-border: #dee2e6;
                --live: #dc3545;
                --live-soft: #ff6b6b;
            }

            body {
                background: var(--bg);
                color: var(--text);
                font-family: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
            }
            header, footer { background: transparent !important; border: none !important; }
            footer { color: var(--muted-text); }
            .events-page { background: transparent; color: var(--text); }
            .events-page .card, .events-page .list-group-item, .events-page .dropdown-menu, .events-page .modal-content {
                background: var(--card);
                border: 1px solid var(--border);
                backdrop-filter: blur(8px);
                -webkit-backdrop-filter: blur(8px);
