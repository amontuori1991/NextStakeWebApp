@page
@model NextStakeWebApp.Pages.Database.IndexModel
@using System.Globalization
@using Microsoft.AspNetCore.Html

@functions {
    IHtmlContent BadgeOkKo(string? val)
    {
        if (val == "OK") return new HtmlString("<span class=\"badge bg-success\">✓</span>");
        if (val == "KO") return new HtmlString("<span class=\"badge bg-danger\">✗</span>");
        return new HtmlString("<span class=\"text-muted\">–</span>");
    }
}

@{
    ViewData["Title"] = "Database";
}

<style>
/* ── Card lega ── */
.league-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: .75rem;
}

.league-stat-card {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.14);
    border-radius: .6rem;
    padding: .75rem .6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: .3rem;
}

.league-stat-header {
    display: flex;
    align-items: center;
    gap: .35rem;
    justify-content: center;
}

.league-stat-logo {
    height: 32px;
    width: auto;
    object-fit: contain;
}

.league-stat-logo-placeholder {
    font-size: 1.5rem;
    line-height: 1;
}

.league-stat-flag {
    height: 14px;
    width: auto;
    vertical-align: middle;
}

.league-stat-name {
    font-size: .72rem;
    font-weight: 600;
    line-height: 1.2;
    max-width: 110px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.league-stat-matches {
    font-size: .68rem;
}

.league-stat-pills {
    display: flex;
    gap: .25rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: .25rem;
}

.league-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    border-radius: .4rem;
    padding: .2rem .35rem;
    min-width: 36px;
}

.pill-ok   { background: rgba(25,135,84,.85);  color:#fff; }
.pill-warn { background: rgba(255,193,7,.85);   color:#111; }
.pill-ko   { background: rgba(220,53,69,.85);   color:#fff; }

.pill-label { font-size: .58rem; opacity: .85; line-height: 1; }
.pill-value { font-size: .8rem;  font-weight: 700; line-height: 1.2; }

/* ── Nomi squadre nella tabella ── */
.team-name-cell {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: .8rem;
    max-width: 90px;
}

@@media (max-width: 576px) {
    .league-stats-grid { grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); }
    .team-name-cell { max-width: 70px; }
}
</style>

<h2>Database</h2>

@if (!Model.IsPlan1)
{
    <div class="alert alert-warning">
        Accesso non consentito.
    </div>
}
else
{
    <!-- ═══════════════════════════════════════════════════════════
         SEZIONE 1 — Aggiorna pronostici
    ═══════════════════════════════════════════════════════════ -->
    <div class="card p-3 mb-4">
        <p class="mb-2">
            Questo comando calcola e salva i pronostici per <b>tutti i match di oggi</b> (Europe/Rome)
            nella tabella <code>NextMatchPredictionsCache</code>.
        </p>

        <form id="refreshForm" method="post" asp-page-handler="RefreshPredictionsStream">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary">
                Aggiorna Pronostici
            </button>
        </form>

        @if (Model.TodayCache != null && Model.TodayCache.Any())
        {
            <hr />
            <h5 class="mt-3 mb-2">Pronostici salvati oggi (cache)</h5>
            <div class="table-responsive">
                <table class="table table-sm table-striped table-dark align-middle mb-0">
                    <thead>
                        <tr>
                            <th>MatchId</th>
                            <th>Data</th>
                            <th>GSC</th>
                            <th>GSO</th>
                            <th>TOT</th>
                            <th>Esito</th>
                            <th>OU</th>
                            <th>GG/NG</th>
                            <th>Combo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (NextStakeWebApp.Pages.Database.IndexModel.CachedPredictionRow r in Model.TodayCache)
                        {
                            <tr>
                                <td>@r.MatchId</td>
                                <td>@(r.EventDate?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                                <td>@(r.GoalSimulatiCasa?.ToString() ?? "-")</td>
                                <td>@(r.GoalSimulatiOspite?.ToString() ?? "-")</td>
                                <td>@(r.TotaleGoalSimulati?.ToString() ?? "-")</td>
                                <td>@(r.Esito ?? "-")</td>
                                <td>@(r.OverUnderRange ?? "-")</td>
                                <td>@(r.GG_NG ?? "-")</td>
                                <td>@(r.ComboFinale ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- Modal log -->
        <div class="modal fade" id="refreshLogModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Aggiornamento pronostici in corso…</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Chiudi"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted" id="refreshProgressText">Progresso: 0/0</small>
                                <small class="text-muted" id="refreshProgressPct">0%</small>
                            </div>
                            <div class="progress" style="height:10px;">
                                <div id="refreshProgressBar" class="progress-bar" role="progressbar"
                                     style="width:0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                        <pre id="refreshLogBox"
                             style="white-space:pre-wrap; margin:0; font-size:.9rem; line-height:1.25; max-height:55vh;"></pre>
                    </div>
                    <div class="modal-footer">
                        <button id="btnCloseLog" type="button" class="btn btn-secondary" data-bs-dismiss="modal" disabled>
                            Chiudi
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.LastRun != null)
        {
            <hr />
            <div class="mt-2">
                <div><b>Ultima esecuzione:</b> @Model.LastRun.Value.ToString("yyyy-MM-dd HH:mm:ss") (ora server)</div>
                <div><b>Match trovati oggi:</b> @Model.TodayMatchesCount</div>
                <div><b>Righe salvate/aggiornate:</b> @Model.UpsertedCount</div>
                @if (!string.IsNullOrWhiteSpace(Model.Error))
                {
                    <div class="alert alert-danger mt-2">@Model.Error</div>
                }
            </div>
        }
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         SEZIONE 2 — Storico verifica pronostici
    ═══════════════════════════════════════════════════════════ -->
    <div class="card p-3">
        <h5 class="mb-3">📊 Storico verifica pronostici (ultimi 30 giorni)</h5>

        @if (Model.VerificaTotali.Totale > 0)
        {
            <!-- ── Statistiche aggregate globali ── -->
            <div class="row g-2 mb-4">
                <div class="col-6 col-md-3">
                    <div class="card text-center p-2 bg-dark">
                        <div class="text-muted small">Partite</div>
                        <div class="fs-4 fw-bold">@Model.VerificaTotali.Totale</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card text-center p-2 @(Model.VerificaTotali.PctEsito >= 55 ? "bg-success" : Model.VerificaTotali.PctEsito >= 45 ? "bg-warning text-dark" : "bg-danger")">
                        <div class="small fw-semibold">Esito</div>
                        <div class="fs-4 fw-bold">@Model.VerificaTotali.PctEsito.ToString("0.0")%</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card text-center p-2 @(Model.VerificaTotali.PctOU >= 60 ? "bg-success" : Model.VerificaTotali.PctOU >= 50 ? "bg-warning text-dark" : "bg-danger")">
                        <div class="small fw-semibold">Over/Under</div>
                        <div class="fs-4 fw-bold">@Model.VerificaTotali.PctOU.ToString("0.0")%</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card text-center p-2 @(Model.VerificaTotali.PctGGNG >= 60 ? "bg-success" : Model.VerificaTotali.PctGGNG >= 50 ? "bg-warning text-dark" : "bg-danger")">
                        <div class="small fw-semibold">GG/NG</div>
                        <div class="fs-4 fw-bold">@Model.VerificaTotali.PctGGNG.ToString("0.0")%</div>
                    </div>
                </div>
            </div>

            <!-- ── Statistiche per lega ── -->
            @if (Model.VerificaTotali.PerLega.Any())
            {
                <h6 class="text-muted mb-2">Per lega</h6>
                <div class="league-stats-grid mb-4">
                    @foreach (var lg in Model.VerificaTotali.PerLega)
                    {
                        <div class="league-stat-card">
                            <!-- Logo + bandiera + nome -->
                            <div class="league-stat-header">
                                @if (!string.IsNullOrWhiteSpace(lg.LeagueLogo))
                                {
                                    <img src="@lg.LeagueLogo" alt="logo" class="league-stat-logo" />
                                }
                                else
                                {
                                    <div class="league-stat-logo-placeholder">⚽</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(lg.LeagueFlag))
                                {
                                    <img src="@lg.LeagueFlag" alt="flag" class="league-stat-flag" />
                                }
                            </div>
                            <div class="league-stat-name" title="@lg.Lega">@lg.Lega</div>
                            <div class="league-stat-matches text-muted">@lg.Totale partite</div>

                            <!-- Tre pill percentuali -->
                            <div class="league-stat-pills">
                                <div class="league-pill @(lg.PctEsito >= 55 ? "pill-ok" : lg.PctEsito >= 45 ? "pill-warn" : "pill-ko")">
                                    <span class="pill-label">Esito</span>
                                    <span class="pill-value">@lg.PctEsito.ToString("0")%</span>
                                </div>
                                <div class="league-pill @(lg.PctOU >= 60 ? "pill-ok" : lg.PctOU >= 50 ? "pill-warn" : "pill-ko")">
                                    <span class="pill-label">O/U</span>
                                    <span class="pill-value">@lg.PctOU.ToString("0")%</span>
                                </div>
                                <div class="league-pill @(lg.PctGGNG >= 60 ? "pill-ok" : lg.PctGGNG >= 50 ? "pill-warn" : "pill-ko")">
                                    <span class="pill-label">GG</span>
                                    <span class="pill-value">@lg.PctGGNG.ToString("0")%</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- ── Dettaglio per giorno (accordion) ── -->
            <h6 class="text-muted mb-2">Dettaglio per giorno</h6>
            <div class="accordion accordion-flush" id="accordionVerifica">
                @{
                    var giorni = Model.Verifica
                        .GroupBy(r => r.EventDate.HasValue ? r.EventDate.Value.Date : DateTime.MinValue)
                        .OrderByDescending(g => g.Key)
                        .ToList();
                    var dayIdx = 0;
                }
                @foreach (var giorno in giorni)
                {
                    dayIdx++;
                    var dayId     = $"day-{dayIdx}";
                    var isFirst   = dayIdx == 1;
                    var dateLabel = giorno.Key != DateTime.MinValue
                        ? giorno.Key.ToString("dddd dd/MM/yyyy", new System.Globalization.CultureInfo("it-IT"))
                        : "–";
                    dateLabel = char.ToUpper(dateLabel[0]) + dateLabel.Substring(1);

                    var dayRows    = giorno.ToList();
                    var dayFin     = dayRows.Where(x => x.EsitoOK != null).ToList();
                    var dayEsitoOk = dayFin.Count > 0 ? dayFin.Count(x => x.EsitoOK    == "OK") : 0;
                    var dayOuOk    = dayFin.Count > 0 ? dayFin.Count(x => x.OverUnderOK == "OK") : 0;
                    var dayGgOk    = dayFin.Count > 0 ? dayFin.Count(x => x.GG_NG_OK   == "OK") : 0;

                    <div class="accordion-item">
                        <h2 class="accordion-header" id="h-@dayId">
                            <button class="accordion-button @(isFirst ? "" : "collapsed")"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#c-@dayId"
                                    aria-expanded="@(isFirst ? "true" : "false")"
                                    aria-controls="c-@dayId">
                                <span class="me-2 fw-semibold">@dateLabel</span>
                                <span class="badge bg-secondary me-1">@dayRows.Count partite</span>
                                @if (dayFin.Count > 0)
                                {
                                    <span class="badge bg-dark me-1">E: @dayEsitoOk/@dayFin.Count</span>
                                    <span class="badge bg-dark me-1">OU: @dayOuOk/@dayFin.Count</span>
                                    <span class="badge bg-dark">GG: @dayGgOk/@dayFin.Count</span>
                                }
                            </button>
                        </h2>
                        <div id="c-@dayId"
                             class="accordion-collapse collapse @(isFirst ? "show" : "")"
                             aria-labelledby="h-@dayId"
                             data-bs-parent="#accordionVerifica">
                            <div class="accordion-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-sm table-striped table-dark align-middle mb-0">
                                        <thead>
                                            <tr>
                                                <th>Ora</th>
                                                <th>Casa</th>
                                                <th>Ospite</th>
                                                <th class="d-none d-md-table-cell">Lega</th>
                                                <th>Pronostico</th>
                                                <th>Risultato</th>
                                                <th class="text-center px-1">E</th>
                                                <th class="text-center px-1">OU</th>
                                                <th class="text-center px-1">GG</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var r in dayRows)
                                            {
                                                <tr>
                                                    <td class="text-nowrap">@(r.EventDate?.ToString("HH:mm") ?? "-")</td>
                                                    <td>
                                                        <span class="team-name-cell">@(r.HomeName ?? "-")</span>
                                                    </td>
                                                    <td>
                                                        <span class="team-name-cell">@(r.AwayName ?? "-")</span>
                                                    </td>
                                                    <td class="d-none d-md-table-cell">
                                                        <div class="d-flex align-items-center gap-1">
                                                            @if (!string.IsNullOrWhiteSpace(r.LeagueLogo))
                                                            {
                                                                <img src="@r.LeagueLogo" alt="" style="height:14px;width:auto;" />
                                                            }
                                                            <small class="text-muted text-truncate" style="max-width:110px;">@(r.Lega ?? "-")</small>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <small>
                                                            @(r.Esito ?? "-")
                                                            &nbsp;·&nbsp;@(r.OverUnderRange ?? "-")
                                                            &nbsp;·&nbsp;@(r.GG_NG ?? "-")
                                                        </small>
                                                    </td>
                                                    <td class="text-nowrap">
                                                        @if (r.GolRealiCasa.HasValue && r.GolRealiOspite.HasValue)
                                                        {
                                                            <b>@r.GolRealiCasa-@r.GolRealiOspite</b>
                                                            <small class="text-muted">(@(r.EsitoReale ?? "-"))</small>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">–</span>
                                                        }
                                                    </td>
                                                    <td class="text-center px-1">@BadgeOkKo(r.EsitoOK)</td>
                                                    <td class="text-center px-1">@BadgeOkKo(r.OverUnderOK)</td>
                                                    <td class="text-center px-1">@BadgeOkKo(r.GG_NG_OK)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted">Nessun dato disponibile. Lo storico si popola automaticamente ogni mattina al prossimo aggiornamento pronostici.</p>
        }
    </div>
}

@section Scripts {
    <script>
        (function () {
            const form = document.getElementById('refreshForm');
            const modalEl = document.getElementById('refreshLogModal');
            const logBox = document.getElementById('refreshLogBox');
            const btnClose = document.getElementById('btnCloseLog');

            const progressText = document.getElementById('refreshProgressText');
            const progressPct = document.getElementById('refreshProgressPct');
            const progressBar = document.getElementById('refreshProgressBar');

            if (!form || !modalEl || !logBox || !btnClose) return;
            let lastIdx = 0;
            let lastTotal = 0;

            function resetProgress() {
                if (progressText) progressText.textContent = 'Progresso: 0/0';
                if (progressPct) progressPct.textContent = '0%';
                if (progressBar) {
                    progressBar.style.width = '0%';
                    progressBar.setAttribute('aria-valuenow', '0');
                }
            }

            function updateProgressFromText(fullText) {
                const all = fullText.match(/📦\s*Batch\s*(\d+)\s*\/\s*(\d+)/g);
                if (!all || !all.length) return;

                const raw = all[0];
                const m = raw.match(/📦\s*Batch\s*(\d+)\s*\/\s*(\d+)/);
                if (!m) return;

                lastIdx = parseInt(m[1], 10);
                lastTotal = parseInt(m[2], 10);

                const pct = lastTotal > 0 ? Math.min(100, Math.round((lastIdx / lastTotal) * 100)) : 0;

                if (progressText) progressText.textContent = `Progresso: ${lastIdx}/${lastTotal}`;
                if (progressPct) progressPct.textContent = `${pct}%`;
                if (progressBar) {
                    progressBar.style.width = `${pct}%`;
                    progressBar.setAttribute('aria-valuenow', String(pct));
                }
            }

            function prependLog(chunk) {
                logBox.textContent = chunk + logBox.textContent;
                const bodyEl = modalEl.querySelector('.modal-body');
                if (bodyEl) bodyEl.scrollTop = 0;
                updateProgressFromText(logBox.textContent);
            }

            form.addEventListener('submit', async function (e) {
                e.preventDefault();

                logBox.textContent = '';
                btnClose.disabled = true;
                resetProgress();

                const modal = bootstrap.Modal.getOrCreateInstance(modalEl, { backdrop: 'static', keyboard: false });
                modal.show();

                const tokenInput = form.querySelector('input[name="__RequestVerificationToken"]');
                const token = tokenInput ? tokenInput.value : null;

                try {
                    const resp = await fetch(form.action, {
                        method: 'POST',
                        headers: token ? { 'RequestVerificationToken': token } : {},
                        body: new FormData(form)
                    });

                    if (!resp.ok) {
                        prependLog(`\n❌ HTTP ${resp.status}\n`);
                        btnClose.disabled = false;
                        return;
                    }

                    if (!resp.body || !resp.body.getReader) {
                        const txt = await resp.text();
                        prependLog(txt);
                        btnClose.disabled = false;
                        return;
                    }

                    const reader = resp.body.getReader();
                    const decoder = new TextDecoder('utf-8');

                    while (true) {
                        const { value, done } = await reader.read();
                        if (done) break;
                        const chunk = decoder.decode(value, { stream: true });
                        prependLog(chunk);
                    }

                    prependLog("\n🏁 STREAM TERMINATO.\n");

                    if (lastTotal > 0 && lastIdx >= lastTotal) {
                        if (progressText) progressText.textContent = `Progresso: ${lastTotal}/${lastTotal}`;
                        if (progressPct) progressPct.textContent = `100%`;
                        if (progressBar) {
                            progressBar.style.width = `100%`;
                            progressBar.setAttribute('aria-valuenow', '100');
                        }
                    }

                    const hasError =
                        logBox.textContent.includes("❌") ||
                        logBox.textContent.includes("ERROR") ||
                        logBox.textContent.includes("FAIL") ||
                        logBox.textContent.includes("SQL ERROR") ||
                        logBox.textContent.includes("EX:");

                    btnClose.disabled = false;

                    if (!hasError) {
                        setTimeout(() => {
                            try { modal.hide(); } catch { }
                            setTimeout(() => location.reload(), 250);
                        }, 900);
                        btnClose.addEventListener('click', () => location.reload(), { once: true });
                    } else {
                        prependLog("\n🛑 ERRORE RILEVATO: finestra lasciata aperta per copia/incolla.\n");
                    }

                } catch (err) {
                    prependLog(`\n❌ ERRORE JS: ${err}\n`);
                    btnClose.disabled = false;
                }
            });
        })();
    </script>
}
